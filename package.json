{
  "name": "cligate",
  "version": "1.3.1",
  "description": "Local AI control plane with a resident private assistant for task execution and a unified model proxy API for Claude Code, Codex CLI, Gemini CLI, OpenClaw, accounts, API keys, logs, and usage.",
  "type": "module",
  "main": "electron-main.cjs",
  "bin": {
    "cligate": "./bin/cli.js"
  },
  "files": [
    "src",
    "bin",
    "public",
    "docs",
    "images",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codeking-ai/cligate.git"
  },
  "bugs": {
    "url": "https://github.com/codeking-ai/cligate/issues"
  },
  "homepage": "https://github.com/codeking-ai/cligate#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node src/index.js",
    "electron": "electron .",
    "fetch:stt-model": "node scripts/fetch-whisper-model.mjs",
    "electron:build": "npm run fetch:stt-model && electron-builder --win",
    "electron:build:all": "npm run fetch:stt-model && electron-builder --win --mac --linux",
    "pack:dry-run": "node scripts/release-check.js --pack-only",
    "release:check": "node scripts/release-check.js",
    "accounts": "node src/cli/accounts.js",
    "accounts:add": "node src/cli/accounts.js add",
    "accounts:add:headless": "node src/cli/accounts.js add --no-browser",
    "accounts:list": "node src/cli/accounts.js list",
    "accounts:remove": "node src/cli/accounts.js remove",
    "accounts:verify": "node src/cli/accounts.js verify",
    "test": "node --test tests/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:all": "node --test tests/unit/*.test.js tests/*.test.js",
    "test:api": "node --test tests/api.test.js",
    "test:routing": "node --test tests/routing.test.js",
    "test:cors": "node --test tests/cors_security.test.js",
    "test:ui": "node --test tests/ui.test.js",
    "test:e2e:protocol:list": "node tests/e2e/lib/scenario-runner.js --list",
    "test:e2e:protocol": "node tests/e2e/lib/scenario-runner.js",
    "test:e2e:protocol:isolated": "node tests/e2e/lib/run-isolated-protocol.js",
    "test:e2e:cli:list": "node tests/e2e/lib/cli-runner.js --list",
    "test:e2e:cli": "node tests/e2e/lib/cli-runner.js",
    "test:e2e:cli:isolated": "node tests/e2e/lib/run-isolated-cli.js",
    "test:e2e:isolated": "npm run test:e2e:protocol:isolated && npm run test:e2e:cli:isolated",
    "desktop:mvp": "node scripts/desktop-agent/mvp-run.js",
    "prepublishOnly": "npm run release:check"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.61.0",
    "@tencent-weixin/openclaw-weixin": "2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "fzstd": "^0.1.1",
    "js-yaml": "^4.2.0",
    "pdfjs-dist": "^6.0.227",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.cligate.app",
    "productName": "CliGate",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "bin/**/*",
      "electron-main.cjs",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "public/**/*",
      "src/desktop-agent/runtime/**/*",
      "src/desktop-agent/runtime-macos/**/*"
    ],
    "win": {
      "icon": "public/icon-dark.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CliGate"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "icon": "public/icon-dark.png",
      "target": [
        "AppImage"
      ],
      "category": "Development"
    }
  },
  "keywords": [
    "claude-code",
    "codex-cli",
    "gemini-cli",
    "openclaw",
    "ai-proxy",
    "openai",
    "anthropic",
    "chatgpt",
    "claude",
    "proxy-server",
    "api-gateway",
    "multi-account",
    "oauth",
    "free-ai",
    "model-routing",
    "ai-control-plane",
    "agent-runtime",
    "ai-agent",
    "mcp",
    "desktop-automation",
    "telegram-bot",
    "feishu",
    "dingtalk",
    "local-first",
    "credential-management",
    "developer-tools",
    "coding-assistant"
  ],
  "license": "AGPL-3.0"
}
